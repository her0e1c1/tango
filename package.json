{
  "name": "tango-web",
  "version": "2.1.0",
  "private": true,
  "packageManager": "npm@12.0.1",
  "engines": {
    "node": ">=24.15.0 <25"
  },
  "scripts": {
    "start": "vite dev",
    "start:all": "firebase emulators:start & storybook dev & vite dev --open & wait",
    "build": "vite build",
    "build:storybook": "storybook build",
    "db": "firebase emulators:start",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "test": "vitest run --no-file-parallelism",
    "test:unit": "vitest run --exclude '**/firestore/**/*.spec.ts'",
    "test:firestore": "vitest run src/action/firestore --no-file-parallelism",
    "fmt": "biome format --write ./src && biome lint --write .",
    "fmt:check": "biome format ./src && biome lint --error-on-warnings .",
    "lint": "npm run lint:tsc && npm run lint:react && biome lint --error-on-warnings .",
    "lint:check": "npm run lint",
    "lint:react": "eslint --max-warnings=0 'src/**/*.{ts,tsx}'",
    "lint:tsc": "tsc -p tsconfig.json --pretty false --noEmit && tsc -p tsconfig.node.json --pretty false --noEmit",
    "storybook": "storybook dev",
    "build-storybook": "npm run build:storybook"
  },
  "dependencies": {
    "@tailwindcss/postcss": "^4.3.2",
    "@tanstack/react-query": "^5.101.2",
    "@types/file-saver": "^2.0.7",
    "@types/katex": "^0.16.8",
    "@types/lodash": "^4.17.24",
    "@types/papaparse": "^5.5.2",
    "@types/uuid": "^9.0.8",
    "classnames": "^2.3.1",
    "file-saver": "^2.0.5",
    "firebase": "^10.14.1",
    "github-markdown-css": "^5.9.0",
    "highlight.js": "^11.11.1",
    "katex": "^0.16.47",
    "lodash": "^4.18.1",
    "moment": "^2.29.1",
    "papaparse": "^5.5.4",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-hook-form": "^7.81.0",
    "react-icons": "^5.7.0",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.18.1",
    "react-swipeable": "^7.0.2",
    "react-use": "^17.6.1",
    "rehype-katex": "^7.0.1",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "sass": "^1.101.0",
    "uuid": "^14.0.1",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.3",
    "@firebase/rules-unit-testing": "^3.0.4",
    "@playwright/test": "^1.61.1",
    "@storybook/addon-docs": "^10.4.6",
    "@storybook/addon-links": "^10.4.6",
    "@storybook/addon-themes": "^10.4.6",
    "@storybook/react": "^10.4.6",
    "@storybook/react-vite": "^10.4.6",
    "@testing-library/jest-dom": "^6.4.2",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "*",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/parser": "^8.64.0",
    "@vitejs/plugin-react": "^6.0.3",
    "eslint": "^10.7.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "firebase-tools": "^15.22.4",
    "jsdom": "^29.1.1",
    "postcss": "^8.5.16",
    "storybook": "^10.4.6",
    "tailwindcss": "^4.3.2",
    "typescript": "^5.9.3",
    "vite": "^8.1.3",
    "vite-tsconfig-paths": "^4.3.2",
    "vitest": "4.1.10"
  }
}
